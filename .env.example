# =============================================================================
# MatchPulse Live — environment variables
# Copy to .env before running docker compose.
# =============================================================================

# ── Pusher Channels (required) ────────────────────────────────────────────────
# Real-time layer for score/clock updates. Free tier at pusher.com/channels.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=                  # e.g. us2, eu, ap1, ap3

# Same Pusher credentials prefixed for the browser bundle (Next.js requirement).
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# LOCAL  (docker compose up): leave MONGODB_URI blank — compose provides the URI.
# PRODUCTION (docker compose -f ... -f docker-compose.prod.yml): set Atlas URI.
MONGODB_URI=
MONGODB_DB=matchpulse

# ── App ───────────────────────────────────────────────────────────────────────
CONTROL_PASSWORD=                # Password for the /login operator console
APP_PORT=4000                    # Host port (default: 4000)

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB=matchpulse

# Pusher Channels (server)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Pusher Channels (browser — must be NEXT_PUBLIC_ to reach the client)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# --- Self-hosted Pusher-protocol server instead (e.g. local soketi) ---
# Set these INSTEAD of PUSHER_CLUSTER / NEXT_PUBLIC_PUSHER_CLUSTER to talk to
# a self-hosted server (like soketi) instead of Pusher Cloud. Not needed for
# `docker compose up` — those values are hardcoded there already, since
# that stack always runs its own local soketi. Only relevant if you run
# `npm run dev` against a soketi instance you started yourself.
# PUSHER_HOST=                    # e.g. localhost (server-side reachable host)
# PUSHER_PORT=6001
# NEXT_PUBLIC_PUSHER_HOST=        # e.g. localhost (browser-reachable host)
# NEXT_PUBLIC_PUSHER_PORT=6001

# Shared operator password for /control (single password, no user accounts)
CONTROL_PASSWORD=

# Vercel Blob — for team logo uploads (future phase)
BLOB_READ_WRITE_TOKEN=
